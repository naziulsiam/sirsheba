# SirSheba Environment Variables
# Copy this to .env.local and fill in your values

# ─── JWT (Required) ────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=your-random-32-character-secret-here

# ─── Email (Optional - console fallback in dev) ─────────────────────────────────
# Get your key at: https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@sirsheba.app

# ─── Supabase (Optional - uses in-memory store without these) ──────────────────
# Get from: https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
